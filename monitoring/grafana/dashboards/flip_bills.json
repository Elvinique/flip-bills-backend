        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"flip-bills-api\"}[5m]))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"flip-bills-api\"}[5m]))", "legendFormat": "P99", "refId": "C" }
      ]
