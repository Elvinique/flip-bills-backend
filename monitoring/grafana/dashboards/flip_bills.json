      "title": "Request Rate (rps)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"flip-bills-api\"}[1m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ]
