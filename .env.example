# ── Server ────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# ── PostgreSQL (Master Wallet Ledger) ─────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flipbills
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=flipbills_db
POSTGRES_SSL_MODE=disable

# ── MongoDB (Dynamic Partner Payloads) ────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flipbills_dynamic

# ── Redis (Session / Queue / Idempotency) ─────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── Payment Aggregators ───────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
MONNIFY_API_KEY=MK_TEST_xxxxx
MONNIFY_SECRET_KEY=xxxxx
MONNIFY_BASE_URL=https://sandbox.monnify.com
INTERSWITCH_CLIENT_ID=xxxxx
INTERSWITCH_SECRET=xxxxx

# ── SMS / Notification ────────────────────────────────
TERMII_API_KEY=xxxxx
TERMII_BASE_URL=https://api.ng.termii.com

# ── Reconciliation Engine ─────────────────────────────
RECONCILIATION_TIMEOUT_SECONDS=45
