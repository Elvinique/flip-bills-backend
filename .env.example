# ── Application ───────────────────────────────────────────────
APP_ENV=development          # development | production
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flipbills
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=flipbills_db
POSTGRES_SSL_MODE=disable    # use "require" in production

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flipbills_dynamic

# ── Redis ─────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-32-byte-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h         # 30 days

# ── Offline QR Signing ────────────────────────────────────────
OFFLINE_QR_SECRET=change-me-to-a-secure-random-32-byte-string

# ── SMS — Termii ──────────────────────────────────────────────
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com

# ── Payment Gateways ──────────────────────────────────────────
# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_WEBHOOK_SECRET=  # set this in your FLW dashboard under "Webhook hash"

# Monnify
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Interswitch
INTERSWITCH_CLIENT_ID=
INTERSWITCH_SECRET=

# ── Reconciliation Engine ─────────────────────────────────────
RECONCILIATION_TIMEOUT_SECONDS=45

# ── Travel Operators ─────────────────────────────────────────
# GIGM
GIGM_API_KEY=
GIGM_BASE_URL=https://api.gigm.com/api

# ABC Transport
ABC_API_KEY=
ABC_BASE_URL=https://api.abctransport.com.ng

# Amadeus GDS (get sandbox credentials at developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com  # swap to live URL in production